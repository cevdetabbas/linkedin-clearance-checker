{
  "manifest_version": 3,
  "name": "LinkedIn Clearance Check",
  "version": "0.6.5",
  "description": "LinkedIn iş ilanlarında security clearance gereksinimini sağ panelde gösterir.",
  "permissions": [
    "sidePanel",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Clearance panelini aç"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "linkedin.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
