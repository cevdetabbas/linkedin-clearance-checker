{
  "manifest_version": 3,
  "name": "LinkedIn Clearance Check",
  "version": "0.7.0",
  "description": "Checks the selected LinkedIn job description for real security-clearance requirements.",
  "permissions": [
    "sidePanel",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Clearance Check"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "clearance-detector.js",
        "content.js"
      ],
      "css": [
        "linkedin.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
